# IP ou DNS da maquina que roda o broker Pulsar.
# Para teste local com todos os containers no mesmo compose, deixe pulsar.
# Para demonstrar entre maquinas fisicas, use o IP da maquina do broker, por exemplo:
# PULSAR_ADVERTISED_ADDRESS=192.168.0.10
PULSAR_ADVERTISED_ADDRESS=pulsar

# URL usada por cliente e servidor para acessar o broker.
# Em maquinas diferentes, troque pelo IP da maquina do broker:
# PULSAR_URL=pulsar://192.168.0.10:6650
PULSAR_URL=pulsar://pulsar:6650

REQUEST_TOPIC=persistent://public/default/prototype-requests
